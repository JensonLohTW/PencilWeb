            "Read",
            "Write",
            "Bash(git:*)",
            "Bash(npx:*)",
            "Bash(uvx:*)",
            "Bash(node:*)",
            "Bash(pnpm:*)",
            "Bash(yarn:*)",
            "mcp__Context7",
            "mcp__SequentialThinking",
            "mcp__chrome-devtools",
            "mcp__serena",
            "mcp__shadcn-ui-mcp",
            "mcp__auggie-mcp"
